{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-chrome",
      "request": "attach",
      "name": "Attach Chrome local debug",
      "address": "localhost",
      "port": 9222,
      "urlFilter": "*://*:5173/*",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**"],
      "trace": true
    },
    {
      "type": "pwa-msedge",
      "request": "attach",
      "name": "Attach Edge local debug",
      "address": "localhost",
      "port": 9222,
      "urlFilter": "*://*:5173/*",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**"],
      "trace": true
    }
  ]
}
